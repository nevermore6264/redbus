# Sao chép thành application-local.yml và điền giá trị thật.

spring:
  mail:
    username: your@gmail.com
    password: your-gmail-app-password

app:
  frontend:
    # IP LAN máy dev (ipconfig → IPv4), không dùng localhost nếu muốn QR quét được trên điện thoại
    url: http://192.168.1.100:5173
  mail:
    from: your@gmail.com
    enabled: true
  payos:
    client-id: your-payos-client-id
    api-key: your-payos-api-key
    checksum-key: your-payos-checksum-key
    return-url: http://localhost:5173/thanh-toan/ket-qua
    cancel-url: http://localhost:5173/ve-cua-toi
    # Webhook PayOS không gọi được localhost. Sau khi thanh toán, trang /thanh-toan/ket-qua
    # tự gọi API PayOS để đồng bộ và cập nhật vé PAID (không cần ngrok khi dev).
